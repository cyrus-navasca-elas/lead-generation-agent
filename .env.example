# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_PLANNER_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_EXTRACT_MODEL=gpt-4o-mini
OPENAI_RELEVANCE_MODEL=gpt-4o-mini

# --- Web search (Tavily) ---
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com

# --- Enrichment ---
SCRAPE_TOP_K=10
SCORE_BLEND_WEIGHT=0.4
ENRICH_MAX_CONCURRENCY=5
SCRAPE_TIMEOUT_SECONDS=8
SCRAPE_MAX_BYTES=30000

# --- ZoomInfo ---
ZOOMINFO_AUTH_MODE=pki
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=
ZOOMINFO_PRIVATE_KEY=
ZOOMINFO_CLIENT_ID=
ZOOMINFO_BASE_URL=https://api.zoominfo.com
ZOOMINFO_MAX_CONCURRENCY=5

# --- Pipeline ---
MAX_COMPANIES=50
MIN_SCORE_FOR_SUMMARY=40

# --- CSLB ---
CSLB_CSV_PATH=data/MasterLicenseData.csv
CSLB_DB_PATH=cache/cslb.sqlite
CSLB_AUTO_INGEST=true
CSLB_LARGE_BOND_THRESHOLD=25000

# --- Modes ---
# When true, OpenAI is stubbed with a deterministic FakeLLMClient.
# (ZoomInfo client is awaiting API access regardless.)
USE_FAKE_CLIENTS=false
DEV_CACHE_ENABLED=false

# --- Misc ---
LOG_LEVEL=INFO
OUT_DIR=out
CONFIG_DIR=configs
